        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "expr": "count(count by (cpu) (k8s_node_cpu_time_seconds_total{k8s_node_name=\"$instance\", cluster=~\"$cluster\", state=\"idle\"}))",
